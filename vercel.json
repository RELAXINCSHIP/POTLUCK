{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        }
    ],
    "crons": [
        {
            "path": "/api/v1/agent/sync-assets",
            "schedule": "0 0 * * *"
        }
    ]
}